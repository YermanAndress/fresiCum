---
import { Heart, Sparkles } from "lucide-astro";
const { title, subtitle } = Astro.props;

// Generamos posiciones aleatorias para los corazones de fondo
const hearts = Array.from({ length: 12 }).map(() => ({
  left: `${Math.random() * 100}%`,
  top: `${Math.random() * 100}%`,
  size: `${12 + Math.random() * 24}px`,
  delay: `${Math.random() * 5}s`,
  duration: `${4 + Math.random() * 4}s`,
}));
---

<header class="relative py-12 md:py-20 text-center overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    {hearts.map((h) => (
      <div 
        class="absolute text-pink-500/10 animate-float" 
        style={`left: ${h.left}; top: ${h.top}; width: ${h.size}; height: ${h.size}; animation-delay: ${h.delay}; animation-duration: ${h.duration};`}
      >
        <Heart size="100%" fill="currentColor" />
      </div>
    ))}
  </div>
  
  <div class="relative z-10">
    <div class="inline-flex items-center gap-2 mb-4 text-pink-500">
      <Sparkles size={20} />
      <span class="text-xs uppercase tracking-[0.2em] text-slate-500 font-medium">Para alguien especial</span>
      <Sparkles size={20} />
    </div>
    
    <h1 class="text-4xl md:text-6xl font-bold text-slate-900 mb-4" style="font-family: var(--font-cursive);">
      {title}
    </h1>
    
    {subtitle && <p class="text-lg text-slate-500 max-w-2xl mx-auto px-4">{subtitle}</p>}
    
    <div class="flex items-center justify-center gap-4 mt-8">
      <div class="h-px w-16 bg-gradient-to-r from-transparent to-pink-500/50" />
      <Heart class="text-pink-500" fill="rgba(236, 72, 153, 0.3)" />
      <div class="h-px w-16 bg-gradient-to-l from-transparent to-pink-500/50" />
    </div>
  </div>
</header>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float { animation: float ease-in-out infinite; }
</style>
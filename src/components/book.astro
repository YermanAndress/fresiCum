---
import { Icon } from 'astro-icon/components';
const { letters } = Astro.props;
---

<div class="letter-book-container relative w-full max-w-6xl mx-auto px-2 md:px-0" data-letters={JSON.stringify(letters)}>
  
  <div class="absolute inset-0 bg-purple-500/5 rounded-[30px] blur-3xl transform translate-y-12 scale-95 pointer-events-none"></div>

  <div class="relative min-h-[550px] md:aspect-[16/11] bg-white rounded-2xl shadow-[0_20px_70px_-10px_rgba(100,50,150,0.15)] border border-purple-100 overflow-hidden">
    
    <div class="absolute left-0 top-0 bottom-0 w-8 md:w-12 bg-gradient-to-r from-purple-500/5 via-purple-500/[0.02] to-transparent z-10 pointer-events-none"></div>
    
    <div id="page-content" class="absolute inset-0 p-6 md:p-16 flex flex-col transition-all duration-500 ease-out">
      
      <div class="mb-4 md:mb-8 pl-4 md:pl-10">
        <p id="page-counter" class="text-[10px] md:text-xs text-purple-400 font-medium tracking-[0.2em] uppercase"></p>
        <h2 id="letter-title" class="text-2xl md:text-4xl font-normal text-purple-950 mt-2 mb-1" style="font-family: var(--font-cursive);"></h2>
        <p id="letter-date" class="text-xs md:text-sm text-purple-300 font-light"></p>
      </div>
      
      <div id="letter-body" class="flex-1 flex flex-col items-center justify-center pl-4 md:pl-10 gap-4 md:gap-6 overflow-y-auto">
        </div>

      <div class="absolute bottom-4 md:bottom-8 left-0 right-0 text-center pointer-events-none">
        <span id="page-number-footer" class="text-[10px] md:text-xs text-purple-300 tracking-widest"></span>
      </div>
    </div>

    <button id="prev-btn" class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-20 w-9 h-9 md:w-11 md:h-11 rounded-full bg-white/80 md:bg-white/60 border border-purple-100 flex items-center justify-center text-purple-400 shadow-sm disabled:opacity-0 transition-all">
      <Icon name="lucide:chevron-left" class="w-5 h-5" />
    </button>
    <button id="next-btn" class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-20 w-9 h-9 md:w-11 md:h-11 rounded-full bg-white/80 md:bg-white/60 border border-purple-100 flex items-center justify-center text-purple-400 shadow-sm disabled:opacity-0 transition-all">
      <Icon name="lucide:chevron-right" class="w-5 h-5" />
    </button>
  </div>
</div>

<script>
  const container = document.querySelector('.letter-book-container') as HTMLElement;
  
  if (container && container.dataset.letters) {
    const letters = JSON.parse(container.dataset.letters);
    let currentIndex = 0;

    const content = document.getElementById('page-content') as HTMLDivElement;
    const title = document.getElementById('letter-title') as HTMLHeadingElement;
    const date = document.getElementById('letter-date') as HTMLParagraphElement;
    const counter = document.getElementById('page-counter') as HTMLParagraphElement;
    const body = document.getElementById('letter-body') as HTMLDivElement;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const footerPage = document.getElementById('page-number-footer') as HTMLSpanElement;

    function updatePage(index: number, direction: 'next' | 'prev') {
      if (!content || !title || !body) return;

      content.style.opacity = '0';
      content.style.transform = direction === 'next' ? 'translateX(-10px)' : 'translateX(10px)';

      setTimeout(() => {
        currentIndex = index;
        const letter = letters[currentIndex];
        
        counter.textContent = `Carta ${currentIndex + 1} de ${letters.length}`;
        title.textContent = letter.title;
        date.textContent = letter.date;
        footerPage.textContent = `— ${currentIndex + 1} —`;

        // Construcción del contenido mezclando imagen y mensaje
        let htmlContent = '';
        
        if (letter.imageUrl) {
          htmlContent += `
            <div class="relative w-full flex flex-col items-center gap-4">
              <img src="${letter.imageUrl}" class="max-h-[350px] md:max-h-[400px] lg:max-h-[500px] w-auto rounded-lg shadow-md border-2 md:border-4 border-white rotate-[-1deg] object-contain" />
              ${letter.message ? `
                <p class="text-purple-800/80 text-center italic text-base md:text-xl px-4 md:px-10 leading-relaxed" style="font-family: var(--font-cursive);">
                  "${letter.message}"
                </p>
              ` : ''}
            </div>
          `;
        } else {
          htmlContent = `<p class="italic text-purple-900 text-center text-xl md:text-3xl px-6" style="font-family: var(--font-cursive);">${letter.message || ''}</p>`;
        }

        body.innerHTML = htmlContent;

        if (prevBtn) prevBtn.disabled = currentIndex === 0;
        if (nextBtn) nextBtn.disabled = currentIndex === letters.length - 1;

        content.style.opacity = '1';
        content.style.transform = 'translateX(0)';
      }, 300);
    }

    prevBtn?.addEventListener('click', () => updatePage(currentIndex - 1, 'prev'));
    nextBtn?.addEventListener('click', () => updatePage(currentIndex + 1, 'next'));

    updatePage(0, 'next');
  }
</script>